class __module_protocol__(Protocol):
    # A module protocol which reflects the result of ``jp.JPackage("jneqsim.process.dynamics")``.

    AdaptiveRK45Integrator: typing.Type[AdaptiveRK45Integrator]
    BDFIntegrator: typing.Type[BDFIntegrator]
    EventScheduler: typing.Type[EventScheduler]
    ExplicitEulerIntegrator: typing.Type[ExplicitEulerIntegrator]
    IntegratorStrategy: typing.Type[IntegratorStrategy]
    RK4Integrator: typing.Type[RK4Integrator]
